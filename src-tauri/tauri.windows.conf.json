{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terax",
        "decorations": false,
        "transparent": true,
        "visible": false,
        "shadow": false
      }
    ]
  },
  "build": {
    "beforeDevCommand": "pnpm dev:teraxctl-sidecar && pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm build:teraxctl-sidecar"
  },
  "bundle": {
    "externalBin": ["binaries/teraxctl"]
  }
}
